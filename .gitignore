*.code-workspace

# ====================================
# FLUTTER / DART / PUB
# ====================================
.dart_tool/
.pub/
.pub-cache/
.pub-cache/
.flutter-plugins-dependencies
.flutter-plugins
*.packages
.packages

# Generated documentation
**/doc/api/

# Flutter iOS build metadata
**/ios/Flutter/.last_build_id
**/ios/Flutter/App.framework
**/ios/Flutter/Flutter.framework
**/ios/Flutter/Generated.xcconfig
**/ios/Flutter/flutter_export_environment.sh

# Flutter macOS specific
**/macos/Flutter/GeneratedPluginRegistrant.swift
**/macos/Flutter/Flutter-Debug.xcconfig
**/macos/Flutter/Flutter-Release.xcconfig
**/macos/Flutter/Flutter-Profile.xcconfig

# Build output
/build/
/app/build/
/coverage/
*.lcov

# Symbolication & obfuscation
app.*.symbols
app.*.map.json

# Lock files (COMMENT OUT for applications, UNCOMMENT for pure Dart packages)
# pubspec.lock

# FVM (Flutter Version Management) – cache is ignored, config is often committed
.fvm/
.fvm/flutter_sdk

